#!/bin/bash
set -euo pipefail
export DEBIAN_FRONTEND=noninteractive
export NEEDRESTART_MODE=a

for attempt in 1 2 3; do
  apt-get update -qq && break || sleep 15
done
apt-get install -y -qq --fix-missing iperf3 mtr-tiny jq curl > /dev/null 2>&1

systemctl stop iperf3 2>/dev/null || true
systemctl disable iperf3 2>/dev/null || true

for attempt in 1 2 3; do
  curl -fsSL https://tailscale.com/install.sh | sh && break || sleep 5
done

sysctl -w net.ipv4.ip_forward=1
sysctl -w net.ipv6.conf.all.forwarding=1
sysctl -w net.core.default_qdisc=fq
sysctl -w net.ipv4.tcp_congestion_control=bbr
sysctl -w net.core.rmem_max=67108864
sysctl -w net.core.wmem_max=67108864
sysctl -w net.ipv4.tcp_rmem="4096 87380 67108864"
sysctl -w net.ipv4.tcp_wmem="4096 65536 67108864"

cpupower frequency-set -g performance 2>/dev/null || true

NETDEV=$(ip -o route get 8.8.8.8 | cut -f 5 -d " ")
ethtool -K "$NETDEV" rx-udp-gro-forwarding on rx-gro-list off 2>/dev/null || true
ethtool -k "$NETDEV" | grep -E "rx-udp-gro-forwarding|rx-gro-list" || true

{{- if .EnableServe }}
# Install fortio for L7 benchmarks
ARCH=$(dpkg --print-architecture)
FORTIO_VERSION="1.67.0"
curl -fsSL "https://github.com/fortio/fortio/releases/download/v${FORTIO_VERSION}/fortio_linux_${ARCH}-${FORTIO_VERSION}.tgz" | tar xz -C /usr/local/bin fortio
chmod +x /usr/local/bin/fortio
{{- end }}

{{- if .AuthKey }}
tailscale up --authkey={{ .AuthKey }} --hostname={{ .Hostname }}
{{- if .EnableSSH }}
tailscale set --ssh
{{- end }}
{{- end }}

{{- if .EnableServe }}
# Start fortio echo server and expose via tailscale serve
fortio server -http-port 8080 -redirect-port disabled &
sleep 2
# Use HTTP serve (port 80) to avoid Let's Encrypt rate limits.
# The L7 reverse proxy overhead is the same with or without TLS.
# HTTPS (port 443) can be enabled via config for TLS termination benchmarks.
tailscale serve --bg --http=80 http://localhost:8080
{{- end }}

touch /tmp/tailbench-ready
